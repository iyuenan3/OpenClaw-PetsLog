{
  "bsonType": "object",
  "required": ["petId", "brand"],
  "permission": {
    "read": "auth.user_id in (SELECT _id FROM users WHERE familyId == (SELECT familyId FROM pets WHERE _id == doc.petId))",
    "create": true,
    "update": true,
    "delete": true
  },
  "properties": {
    "_id": { "description": "ID，系统自动生成" },
    "petId": { "bsonType": "string", "description": "宠物 ID" },
    "brand": { "bsonType": "string", "description": "品牌" },
    "product": { "bsonType": "string", "description": "产品型号" },
    "type": { "bsonType": "string", "description": "粮食类型" },
    "startDate": { "bsonType": "timestamp", "description": "开始日期" },
    "endDate": { "bsonType": "timestamp", "description": "结束日期" },
    "note": { "bsonType": "string", "description": "备注" }
  }
}
